.mainText {
  background-color: var(--main);
  font-family: "Inter", sans-serif;
  color: #534545;
  padding: 2rem;
}

.mainText h1 {
  font-weight: 400;
  margin-bottom: 20px;
  font-size: x-large;
  align-self: center;
  position: relative;
  display: inline-block;
}

.mainText h2 {
  font-weight: 400;
  font-size: large;
  align-self: self-start;
  margin: 0.5lh 0;
}

.mainText p {
  text-align: justify;
  white-space: pre-wrap;
  line-height: 1.5lh;
  font-weight: 300;
}

.mainText hr {
  width: 100%;
  align-self: start;
}
